# =================================================================
# Spendsy Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =================================================================

# --- Database ---
POSTGRES_DB=spendsy
POSTGRES_USER=smartuser
POSTGRES_PASSWORD=smartpass
DB_HOST=localhost
DB_PORT=5434
DB_USER=smartuser
DB_PASSWORD=smartpass
DB_NAME=spendsy

# --- Security (change these in production!) ---
JWT_SECRET=super_secret_jwt_key_that_is_long_enough_32c
JWT_ALGORITHM=HS256
INTERNAL_API_KEY=internal-dev-key-that-is-long-enough-32c

# --- Rate Limiting ---
AUTH_RATE_LIMIT_WINDOW_SECONDS=120
AUTH_RATE_LIMIT_LOGIN=200
AUTH_RATE_LIMIT_REGISTER=50

# --- Environment ---
ENVIRONMENT=development

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Service URLs ---
AUTH_SERVICE_URL=http://localhost:8001
FINANCE_SERVICE_URL=http://localhost:8002
AI_SERVICE_URL=http://localhost:8004
SPENDSY_AI_URL=http://localhost:8005
SPENDSY_MCP_URL=http://localhost:8006

# --- External APIs (optional, needed for AI features) ---
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
