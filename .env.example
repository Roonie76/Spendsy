# Database Configuration
POSTGRES_DB=smartspend
POSTGRES_USER=smartuser
POSTGRES_PASSWORD=smartpass

# Security
JWT_SECRET=your-super-secret-key-here
JWT_ALGORITHM=HS256
INTERNAL_API_KEY=internal-dev-key

# Rate Limiting
AUTH_RATE_LIMIT_WINDOW_SECONDS=120
AUTH_RATE_LIMIT_LOGIN=200
AUTH_RATE_LIMIT_REGISTER=50

# Environment
ENVIRONMENT=development
