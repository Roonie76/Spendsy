# Database Configuration
POSTGRES_DB=spendsy
POSTGRES_USER=smartuser
POSTGRES_PASSWORD=smartpass

DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=spendsy
DB_USER=smartuser
DB_PASSWORD=smartpass

# Security
JWT_SECRET=your-super-secret-32-character-key-here
JWT_ALGORITHM=HS256
INTERNAL_API_KEY="your-super-secret-internal-api-key-here"

# Gemini AI API Key for Statement Parsing
GEMINI_API_KEY="your-gemini-api-key-here"

# Rate Limiting
AUTH_RATE_LIMIT_WINDOW_SECONDS=120
AUTH_RATE_LIMIT_LOGIN=200
AUTH_RATE_LIMIT_REGISTER=50

# Environment
ENVIRONMENT=development

# Service URLs (for direct access or overrides)
AUTH_SERVICE_URL=http://localhost:8001
FINANCE_SERVICE_URL=http://localhost:8002
AI_SERVICE_URL=http://localhost:8004
SPENDSY_AI_URL=http://localhost:8005
SPENDSY_MCP_URL=http://localhost:8006

# External APIs
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
